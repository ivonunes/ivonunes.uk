<footer>
  <div class="social">
    {% for social in site.social %}
    {% set isExternal = social.url | startsWith('http') %}
    {% set relValue = 'noopener' %}
    {% set linkTitle = site.author.name + ' on ' + social.name %}
    {% if social.name == 'RSS' %}
      {% set linkTitle = site.author.name + ' RSS Feed' %}
    {% endif %}
    {% if social.name == 'Email' %}
      {% set linkTitle = 'Email ' + site.author.name %}
    {% endif %}
    {% if isExternal and not (social.url | startsWith('mailto:')) and not (social.url | endsWith('.xml')) %}
      {% set relValue = 'me noopener' %}
    {% endif %}
    <a href="{{ social.url }}"{% if isExternal %} target="_blank" rel="{{ relValue }}"{% endif %} class="social-link {{ social.className }}" title="{{ linkTitle }}"><i class="{{ social.icon }}"></i></a>
    {% endfor %}
  </div>
  <p>Made with <span class="red">♥</span> in the UK.</p>
</footer>
<button class="to-top" onclick="window.scrollTo({ top: 0, behavior: 'smooth' });" aria-label="Scroll to top">
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512"><path d="M201.4 137.4c12.5-12.5 32.8-12.5 45.3 0l160 160c12.5 12.5 12.5 32.8 0 45.3s-32.8 12.5-45.3 0L224 205.3 86.6 342.6c-12.5 12.5-32.8 12.5-45.3 0s-12.5-32.8 0-45.3l160-160z"/></svg>
</button>
